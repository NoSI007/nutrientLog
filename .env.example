# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# USDA_API_KEY: Optional API key for USDA FoodData Central API.
# It defaults to DEMO_KEY which enables 30 requests/hour by default.
USDA_API_KEY=DEMO_KEY

# NUTRITIONIX_APP_ID: Optional App ID for Nutritionix API.
NUTRITIONIX_APP_ID=NUTRITIONIX_APP_ID_DEFAULT_VALUE

# NUTRITIONIX_API_KEY: Optional API Key for Nutritionix API.
NUTRITIONIX_API_KEY=NUTRITIONIX_API_KEY_DEFAULT_VALUE
