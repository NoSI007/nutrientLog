<Window x:Class="DesktopNutritionTracker.FoodEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modify Consumable Intake Detail" Height="500" Width="550"
        WindowStartupLocation="CenterOwner" Background="#F3F4F6"
        Foreground="#111827" BorderBrush="#D1D5DB" BorderThickness="1"
        ResizeMode="NoResize" ShowInTaskbar="False">
    
    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="BgCard" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentPrimary" Color="#2563EB"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#4B5563"/>
        <SolidColorBrush x:Key="BorderColor" Color="#D1D5DB"/>
        <SolidColorBrush x:Key="StatusGreen" Color="#059669"/>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="CaretBrush" Value="#111827"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Height" Value="30"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title Header -->
            <RowDefinition Height="*"/>    <!-- Main Form Fields Grid -->
            <RowDefinition Height="Auto"/> <!-- Action Buttons Bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="✏️ Edit Nutrient &amp; Ingestion Metrics" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentPrimary}"/>
            <TextBlock Text="Alter the servings, meal category, or individual nutrient values below. These changes apply directly to your workbook." FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0"/>
            <Separator Background="{StaticResource BorderColor}" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Form Fields -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
            <StackPanel>
                <!-- Base Fields -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Food/Consumable Name:" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="FoodNameInput" Style="{StaticResource InputTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Meal Intake Category:" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox x:Name="MealTypeCombo" Height="30" VerticalContentAlignment="Center" Background="#FFFFFF" BorderBrush="#D1D5DB" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Serving Quantity:" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="QuantityInput" Style="{StaticResource InputTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Unit Reference:" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="UnitInput" Style="{StaticResource InputTextBox}"/>
                    </StackPanel>
                </Grid>

                <!-- Nutrients Group header -->
                <Border Background="#1A5076EC" CornerRadius="4" Padding="10,6" Margin="0,5,0,10">
                    <TextBlock Text="Custom Nutrient Core Adjustments" FontWeight="Bold" Foreground="{StaticResource AccentPrimary}" FontSize="12" HorizontalAlignment="Center"/>
                </Border>

                <!-- 2 Column Nutrient Inputs -->
                <UniformGrid Columns="2">
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Calories (kcal):" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,3"/>
                        <TextBox x:Name="NutrientCalories" Style="{StaticResource InputTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Water/Hydration (ml):" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,3"/>
                        <TextBox x:Name="NutrientWater" Style="{StaticResource InputTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Protein (g):" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,3"/>
                        <TextBox x:Name="NutrientProtein" Style="{StaticResource InputTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Carbohydrates (g):" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,3"/>
                        <TextBox x:Name="NutrientCarbs" Style="{StaticResource InputTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Total Fat (g):" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,3"/>
                        <TextBox x:Name="NutrientFat" Style="{StaticResource InputTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Dietary Fiber (g):" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,3"/>
                        <TextBox x:Name="NutrientFiber" Style="{StaticResource InputTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Sodium (mg):" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,3"/>
                        <TextBox x:Name="NutrientSodium" Style="{StaticResource InputTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Potassium (mg):" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,3"/>
                        <TextBox x:Name="NutrientPotassium" Style="{StaticResource InputTextBox}"/>
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer actions -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Name="ErrorText" Text="" Foreground="Red" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"/>
            
            <Button Grid.Column="1" Content="Save &amp; Commit" Background="{StaticResource AccentPrimary}" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Padding="15,6" FontWeight="Bold" Click="Save_Click" Width="130" Height="32">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Grid.Column="2" Content="Cancel" Background="Transparent" Foreground="{StaticResource TextSecondary}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="15,6" Click="Cancel_Click" Width="90" Height="32">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>
